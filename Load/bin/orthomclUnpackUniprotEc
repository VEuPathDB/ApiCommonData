#!/usr/bin/perl

use strict;
use Data::Dumper;


my ($inputFile, $outputFile, $orthomclTaxonAbbrev) = @ARGV;

usage() unless $inputFile && $outputFile && $orthomclTaxonAbbrev;

open(IN, $inputFile) || die "Can't open input file $inputFile \n";
open(OUT, ">$outputFile") || die "Can't open output file '$outputFile'\n";

=head

Supports two input formats:

Format 1 - two-column tab-delimited (Vectorbase Biomart):
GENE           EC_first; EC_second; etc
Q54W07         3.6.-.-; 2.7.11.1

Format 2 - four-column tab-delimited (UniProt export):
Entry  Gene Names  Organism  EC number
A0A0A7EPL0  PIAL1 ...  Arabidopsis thaliana  2.3.2.-

The format needs to change to:
dicd|Q54W07    3.6.-.-
dicd|Q54W07    2.7.11.1

=cut

my %geneEcCount;
my $firstLine = 1;
my $numCols;

while (<IN>) {
    my $line = $_;
    chomp $line;
    $line =~ s/\r//;  # strip Windows line endings
    my @cols = split /\t/, $line;

    if ($firstLine) {
        $firstLine = 0;
        $numCols = scalar @cols;
        # Skip header if first column is "Entry" or "Gene" (case-insensitive)
        next if $cols[0] =~ /^(entry|gene)$/i;
    }

    my ($gene, $ecField);
    if ($numCols >= 4) {
        # UniProt 4-column format: Entry, Gene Names, Organism, EC number
        $gene    = $cols[0];
        $ecField = $cols[3];
    } else {
        # Two-column format: Gene, EC numbers
        $gene    = $cols[0];
        $ecField = $cols[1];
    }

    next unless defined $gene && $gene ne '';
    next unless defined $ecField && $ecField ne '';

    my @ecNumbers = split /;\s*/, $ecField;
    foreach my $ecNumber (@ecNumbers) {
        $ecNumber =~ s/^\s+|\s+$//g;
        if ($ecNumber =~ /[0-9]{1,3}(\.(\-|[0-9]{1,3})){3}/) {
            if (!$geneEcCount{$gene.$ecNumber}) {
                print OUT "$orthomclTaxonAbbrev|$gene\t$ecNumber\n";
                $geneEcCount{$gene.$ecNumber} = 1;
            }
        }
    }
}

close IN;
close OUT;


sub usage {

die "
Parse a tab-delimited file containing gene IDs and EC numbers.

Usage: inputDownloadFile outputTabFile orthomclTaxonAbbrev

Where:
  inputDownloadFile:  a tab-delimited file in one of two formats:
    - Two-column (Vectorbase Biomart): Gene<tab>EC_first; EC_second; ...
    - Four-column (UniProt export):    Entry<tab>Gene Names<tab>Organism<tab>EC number
    An optional header line is automatically detected and skipped.
  outputTabFile: two columns ID and EC number.  One line per EC assignment.
  orthomclTaxonAbbrev: to be prepended on the gene ID (e.g. atha)

";
}
